# ══════════════════════════════════════════════════
# GyMy — Variables de entorno
# ══════════════════════════════════════════════════
# Renombra este archivo a .env para desarrollo local
# En Railway añádelas en Settings > Variables

# ── Base de datos PostgreSQL ──────────────────────
# Railway te la da automáticamente al añadir el plugin PostgreSQL
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# ── JWT ───────────────────────────────────────────
JWT_SECRET=pon_aqui_un_string_muy_largo_y_secreto_123
JWT_REFRESH_SECRET=otro_string_largo_diferente_456
JWT_EXPIRES_IN=15m

# ── Entorno ───────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── URL del frontend (tu dominio Railway) ─────────
FRONTEND_URL=https://gymy-production.up.railway.app

# ── Anthropic (para importación IA de sesiones) ───
ANTHROPIC_API_KEY=sk-ant-...

# ── Email recuperación de contraseña (opcional) ───
# Para Gmail: activa autenticación de 2 factores y genera una App Password
EMAIL_USER=tuemail@gmail.com
EMAIL_PASS=tu_app_password_gmail
